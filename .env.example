# ─────────────────────────────────────────
# DeepThought Configuration
# ─────────────────────────────────────────

# ── Internal LLM Endpoint ────────────────
INTERNAL_LLM_BASE_URL=http://your-llm-endpoint:3001/v1
INTERNAL_LLM_API_KEY=your-api-key-here

# ── Model Selection ──────────────────────
# Examples: gpt-4o, claude-opus-4-6, deepseek-v3, qwen3-72b
MAVERICK_MODEL=gpt-4o
DEBATE_DEEP_THINKER_MODEL=gpt-4o
DEBATE_CODE_EXPERT_MODEL=gpt-4o
DEBATE_JUDGE_MODEL=gpt-4o
TID_FORMATTER_MODEL=gpt-4o
EMBEDDING_MODEL=BAAI/bge-m3

# ── Claude (Reality Checker) ─────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here
REALITY_CHECKER_MODEL=claude-sonnet-4-5

# ── Vector Database ──────────────────────
VECTORDB_TYPE=chroma
VECTORDB_PATH=./data/vectorstore
QDRANT_URL=http://localhost:6333

# ── Data Collection ──────────────────────
GITHUB_TOKEN=your-github-token-here
DATA_RAW_PATH=./data/raw
DATA_PROCESSED_PATH=./data/processed

# ── Pipeline Settings ────────────────────
LAMBDA_MMR=0.7
MAX_REVISION_ITERATIONS=3
MIN_CONFIDENCE_SCORE=0.75
MAX_DEBATE_ROUNDS=3

# ── Logging ──────────────────────────────
LOG_LEVEL=INFO
LOG_PATH=./logs
